    "@anthropic-ai/sdk": "^0.20.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai",
    "workflow",
    "claude-code",
    "copilot",
    "cursor",
    "windsurf",
    "opencode",
    "skills",
    "openspec",
    "obsidian",
    "context",
    "developer-tools",
    "cli",
    "sdd",
    "persistent",
    "plugin",
    "ai-context-plugin"
  ],
  "homepage": "https://github.com/kousthubha-sky/workflow#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kousthubha-sky/workflow.git"
  },
  "bugs": {
    "url": "https://github.com/kousthubha-sky/workflow/issues"
