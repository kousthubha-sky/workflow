{
  "name": "@kousthubha/persistent",
  "version": "0.3.0",
  "description": "Universal AI workflow bootstrap — one command, any stack, any agent.",
  "type": "module",
  "bin": {
    "persistent": "./bin/persistent.js"
  },
  "files": [
    "bin/",
